# Environment / secrets — NEVER commit
.env
*.env
.env.*

# Claude skills (含む認証情報・VPSトークン) — NEVER commit (C6修正)
.claude/skills/

# Token/credential rotation files (平文token記録) — NEVER commit (C6-B1修正)
# 例外: *_procedure_*.md (手順書) はcommit対象
data/token_rotation_*
data/credentials_*

# Gmail OAuth2 credentials — NEVER commit
credentials.json
gmail_token.json

# Saxo token
.saxo_token.json

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# macOS
.DS_Store

# Logs
*.log

# Local overrides
spx_bot.py.local
result.html

# Backup / rollback artifacts (.bak / .backup) — never commit (2026-04-25)
# 個別 cycle backup や手動 rollback file (chronos_bot.py.bak_cycle2_*) を tracked にしない
# 既存 tracked: data/condor_pnl.json.bak_20260418_050839_dedup は影響なし (tracked file は ignore 無効)
*.bak*
*.backup
*.backup.*
*.backup_*
.bak_*/
