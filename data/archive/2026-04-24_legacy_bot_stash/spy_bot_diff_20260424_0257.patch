+def calc_dynamic_gamma_atr_trigger(vix: float) -> float:
+    """VIXレベルに応じたGammaScalp ATRトリガー係数を動的算出する。
+
+    設計根拠:
+      - VIX高 → 原資産の動きが大きい → より大きな閾値でないとノイズでスキャルプが多発
+      - VIX低 → 動きが小さい → 低い閾値でスキャルプ機会を捕捉する
+      - ただしVIX<20ではGammaScalp自体を無効化するため低域の微調整は不要
+    参照: common/gamma_scalping.py の DELTA_BAND_VIX_* 設計思想を踏襲
+
+    Args:
+        vix: 現在VIX指数
+
+    Returns:
+        ATR_TRIGGER係数 (0.25 〜 0.55)
+    """
+    if vix >= 40:
+        return 0.55   # 超高ボラ: ノイズ多発防止で高め
+    elif vix >= 30:
+        return 0.48   # 高ボラ
+    elif vix >= 25:
+        return 0.42   # 中高ボラ
+    elif vix >= 20:
+        return 0.35   # 中ボラ（標準エントリー環境）
+    else:
+        return GAMMA_SCALP_ATR_TRIGGER  # フォールバック（VIX<20は通常無効）
+
+
+def calc_dynamic_gamma_interval_min(vix: float) -> float:
+    """VIXレベルに応じたGammaScalp最小インターバル（分）を動的算出する。
+
+    VIX高 → 動きが速い → 短いインターバルで多く刈り取る
+    VIX低 → 動きが遅い → 長いインターバルでノイズ排除
+
+    Args:
+        vix: 現在VIX指数
+
+    Returns:
+        最小インターバル（分）: 5.0 〜 20.0
+    """
+    if vix >= 40:
+        return 5.0    # 超高ボラ: 頻繁にスキャルプ可能
+    elif vix >= 30:
+        return 7.0
+    elif vix >= 25:
+        return 10.0   # デフォルト
+    elif vix >= 20:
+        return 15.0
+    else:
+        return GAMMA_SCALP_MIN_INTERVAL_MIN  # フォールバック
+
